---
import { Image } from 'astro:assets';
import { site } from '../data/site';
import heroImage from '../assets/hero.jpg';

// Home-page nav (the home hero carries its own nav instead of the site header).
const nav = [
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Contact', href: '/contact' },
];

// Inline SVG icons keyed by normalized social label, so socials render as
// glyphs (like the reference). Unknown labels fall back to a text label.
const icons: Record<string, string> = {
  instagram:
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c2.7 0 3 0 4.1.06 1.1.05 1.8.24 2.4.5.7.27 1.2.62 1.8 1.2.6.6.95 1.1 1.2 1.8.26.6.45 1.3.5 2.4.06 1.1.06 1.4.06 4.1s0 3-.06 4.1c-.05 1.1-.24 1.8-.5 2.4a4.8 4.8 0 0 1-1.2 1.8c-.6.6-1.1.95-1.8 1.2-.6.26-1.3.45-2.4.5-1.1.06-1.4.06-4.1.06s-3 0-4.1-.06c-1.1-.05-1.8-.24-2.4-.5a4.8 4.8 0 0 1-1.8-1.2 4.8 4.8 0 0 1-1.2-1.8c-.26-.6-.45-1.3-.5-2.4C2 15 2 14.7 2 12s0-3 .06-4.1c.05-1.1.24-1.8.5-2.4.27-.7.62-1.2 1.2-1.8.6-.6 1.1-.95 1.8-1.2.6-.26 1.3-.45 2.4-.5C9 2 9.3 2 12 2Zm0 1.8c-2.7 0-3 0-4 .06-.9.04-1.4.2-1.7.33-.43.17-.74.37-1.06.7-.32.31-.52.62-.69 1.05-.13.34-.29.84-.33 1.74-.05 1-.06 1.3-.06 4s.01 3 .06 4c.04.9.2 1.4.33 1.74.17.43.37.74.7 1.06.31.32.62.52 1.05.69.34.13.84.29 1.74.33 1 .05 1.3.06 4 .06s3 0 4-.06c.9-.04 1.4-.2 1.74-.33.43-.17.74-.37 1.06-.7.32-.31.52-.62.69-1.05.13-.34.29-.84.33-1.74.05-1 .06-1.3.06-4s0-3-.06-4c-.04-.9-.2-1.4-.33-1.74a2.9 2.9 0 0 0-.7-1.06 2.9 2.9 0 0 0-1.05-.69c-.34-.13-.84-.29-1.74-.33-1-.05-1.3-.06-4-.06Zm0 3.06a5.14 5.14 0 1 1 0 10.28 5.14 5.14 0 0 1 0-10.28Zm0 1.8a3.34 3.34 0 1 0 0 6.68 3.34 3.34 0 0 0 0-6.68Zm5.34-3.2a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z"/></svg>',
  email:
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm1.4 1.8L12 11.9l7.6-5.1H4.4ZM20 8.2l-8 5.4-8-5.4V17h16V8.2Z"/></svg>',
  facebook:
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z"/></svg>',
  youtube:
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 12s0-3.2-.4-4.7c-.23-.83-.9-1.48-1.73-1.7C19.36 5.2 12 5.2 12 5.2s-7.36 0-8.87.4c-.83.22-1.5.87-1.73 1.7C1 8.8 1 12 1 12s0 3.2.4 4.7c.23.83.9 1.48 1.73 1.7 1.51.4 8.87.4 8.87.4s7.36 0 8.87-.4c.83-.22 1.5-.87 1.73-1.7.4-1.5.4-4.7.4-4.7Zm-13 3.5v-7l6 3.5-6 3.5Z"/></svg>',
  tiktok:
    '<svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.5 3c.3 2.1 1.5 3.4 3.5 3.6v2.4c-1.2.1-2.4-.2-3.5-.8v5.6c0 3.4-2.5 5.7-5.6 5.7A5.4 5.4 0 0 1 5.5 14c0-3.1 2.7-5.4 5.9-5v2.5c-.3-.1-.7-.1-1-.1-1.5 0-2.6 1.2-2.5 2.7 0 1.4 1.2 2.5 2.6 2.5 1.5 0 2.6-1.1 2.6-2.7V3h2.9Z"/></svg>',
};
const iconFor = (label: string) => icons[label.trim().toLowerCase()] ?? null;

// Split the name so it breaks as "Jenny" / "De Jaeger" on narrow widths.
const [firstName, ...nameRest] = site.name.split(' ');
const lastName = nameRest.join(' ');
---
<section class="grid h-dvh overflow-hidden grid-rows-[minmax(0,1fr)_auto] md:grid-rows-1 md:grid-cols-2">
  <div class="order-2 md:order-1 min-h-0 flex flex-col items-center justify-between gap-6 text-center px-8 py-8 md:py-12">
    <h1 class="text-sm md:text-base font-semibold uppercase tracking-[0.35em] leading-tight">
      <span class="whitespace-nowrap">{firstName}</span> <span class="whitespace-nowrap">{lastName}</span>
    </h1>

    <div class="max-w-md">
      <p class="text-base md:text-lg leading-relaxed text-neutral-700">{site.intro}</p>
      <nav class="mt-8 md:mt-10 flex flex-wrap justify-center gap-x-6 gap-y-2 text-[11px] font-semibold uppercase tracking-[0.2em]">
        {nav.map((item) => (
          <a href={item.href} class="text-neutral-800 hover:text-black transition-colors">{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="flex items-center gap-5 text-neutral-700">
      {site.socials.map((s) => {
        const external = s.href.startsWith('http');
        const icon = iconFor(s.label);
        return (
          <a
            href={s.href}
            aria-label={s.label}
            class="hover:text-black transition-colors"
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener' : undefined}
          >
            {icon ? <Fragment set:html={icon} /> : <span class="text-[11px] uppercase tracking-[0.2em]">{s.label}</span>}
          </a>
        );
      })}
    </div>
  </div>

  <div class="order-1 md:order-2 relative min-h-0 overflow-hidden">
    <Image
      src={heroImage}
      alt={`${site.name} — featured portrait`}
      class="absolute inset-0 w-full h-full object-cover object-[center_30%]"
      widths={[400, 600, 800, 1200]}
      sizes="(max-width: 768px) 100vw, 50vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
</section>
